#!/usr/bin/env bash
set -euo pipefail

script_dir() {
    local src="${BASH_SOURCE[0]}"
    while [[ -h "$src" ]]; do
        local dir
        dir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
        src="$(readlink "$src")"
        [[ "$src" != /* ]] && src="$dir/$src"
    done
    (cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)
}

usage() {
    cat <<'EOF'
Usage:
  ./bootstrap [--interactive] [--dry-run] [--force] [<target>] [--prefix <PREFIX>]
  ./bootstrap --non-interactive [--dry-run] [--force] <target> --prefix <PREFIX>
  ./bootstrap [--dry-run] [--force] --prefix <PREFIX> <target>
  ./bootstrap [--dry-run] [--force] <target> --prefix <PREFIX>

Required arguments:
  <target>              Target project directory to inspect or install into.
  --prefix <PREFIX>     Short identifier used by the target Beads database.

Options:
  --interactive         Run the guided TTY wizard when required choices are
                        missing. Requires a terminal and is not used in CI.
  --non-interactive     Never prompt. Requires <target> and --prefix <PREFIX>.
                        This is the default in CI or non-TTY contexts.
  --dry-run             Print planned creates, skips, and conflicts without
                        writing files. Does not require bd.
  --force               Overwrite differing managed scaffold files only.
                        Does not overwrite .beads/, .git/, credentials,
                        symlinks, transient state contents, or unmanaged paths.
  -h, --help            Show this help text.

Notes:
  TTY invocations with missing required choices route into interactive mode.
  CI, non-TTY, and explicit --non-interactive invocations require all inputs and
  exit instead of waiting for input.
  The installer reads assets/scaffold/manifest.txt as the managed-path
  contract. Real installs require bd and fail before target writes when bd is
  unavailable or when managed-path conflicts are present.
EOF
}

die() {
    printf 'bootstrap: %s\n\n' "$1" >&2
    usage >&2
    exit 2
}

error_exit() {
    printf 'bootstrap: %s\n' "$1" >&2
    exit "${2:-1}"
}

set_target() {
    local value="$1"
    local -n target_var="$2"

    if [[ -n "$target_var" ]]; then
        die "unexpected extra argument: $value"
    fi

    target_var="$value"
}

parse_args() {
    local -n target_ref="$1"
    local -n prefix_ref="$2"
    local -n dry_run_ref="$3"
    local -n force_ref="$4"
    local -n mode_ref="$5"
    shift 5

    while (($#)); do
        case "$1" in
            -h|--help)
                usage
                exit 0
                ;;
            --dry-run)
                dry_run_ref=1
                shift
                ;;
            --force)
                force_ref=1
                shift
                ;;
            --interactive)
                if [[ "$mode_ref" == "non_interactive" ]]; then
                    die "choose either --interactive or --non-interactive, not both"
                fi
                mode_ref="interactive"
                shift
                ;;
            --non-interactive)
                if [[ "$mode_ref" == "interactive" ]]; then
                    die "choose either --interactive or --non-interactive, not both"
                fi
                mode_ref="non_interactive"
                shift
                ;;
            --prefix)
                shift
                if (($# == 0)) || [[ "$1" == -* ]]; then
                    die "--prefix requires a value"
                fi
                prefix_ref="$1"
                shift
                ;;
            --prefix=*)
                prefix_ref="${1#*=}"
                if [[ -z "$prefix_ref" ]]; then
                    die "--prefix requires a value"
                fi
                shift
                ;;
            --)
                shift
                while (($#)); do
                    set_target "$1" target_ref
                    shift
                done
                ;;
            -*)
                die "unknown option: $1"
                ;;
            *)
                set_target "$1" target_ref
                shift
                ;;
        esac
    done
}

is_ci_context() {
    [[ -n "${CI:-}" ]]
}

has_tty_context() {
    [[ -t 0 && -t 1 ]]
}

resolve_mode() {
    local requested_mode="$1" target="$2" prefix="$3"
    local -n resolved_mode_ref="$4"

    if [[ "$requested_mode" != "auto" ]]; then
        resolved_mode_ref="$requested_mode"
        return 0
    fi

    if [[ -n "$target" && -n "$prefix" ]]; then
        resolved_mode_ref="non_interactive"
        return 0
    fi

    if ! is_ci_context && has_tty_context; then
        resolved_mode_ref="interactive"
        return 0
    fi

    resolved_mode_ref="non_interactive"
}

validate_non_interactive_inputs() {
    local target="$1" prefix="$2"
    local -a missing=()

    [[ -n "$target" ]] || missing+=("<target>")
    [[ -n "$prefix" ]] || missing+=("--prefix <PREFIX>")

    if ((${#missing[@]})); then
        die "missing required inputs in non-interactive mode: ${missing[*]}"
    fi

    [[ "$prefix" =~ ^[A-Za-z0-9_-]+$ ]] \
        || die "invalid --prefix '$prefix'; allowed: letters, digits, hyphen, underscore"
}

run_interactive_mode() {
    local target="$1" prefix="$2"
    local reason="interactive mode was selected"
    if [[ -z "$target" || -z "$prefix" ]]; then
        reason="required choices are missing"
    fi

    cat >&2 <<'EOF'
bootstrap: starting interactive mode.
EOF
    printf 'Reason: %s.\n' "$reason" >&2
    cat >&2 <<'EOF'
Interactive prompt collection is reserved for the follow-on wizard tasks, so no
target files were written.

For automation, provide all required inputs:
  ./bootstrap --non-interactive <target> --prefix <PREFIX>
EOF
    return 2
}

normalize_rel_path() {
    local rel="$1"
    rel="${rel#./}"
    rel="${rel%/}"
    printf '%s\n' "$rel"
}

path_has_parent_ref() {
    local rel="$1" part
    IFS='/' read -r -a parts <<<"$rel"
    for part in "${parts[@]}"; do
        [[ "$part" == ".." ]] && return 0
    done
    return 1
}

path_has_component() {
    local rel="$1" wanted="$2" part
    IFS='/' read -r -a parts <<<"$rel"
    for part in "${parts[@]}"; do
        [[ "$part" == "$wanted" ]] && return 0
    done
    return 1
}

is_credential_path() {
    local rel="$1" base
    base="$(basename -- "$rel")"
    case "$base" in
        .env|.env.*|*credential*|*credentials*|*secret*|*secrets*|*token*|*tokens*|id_rsa|id_dsa|id_ecdsa|id_ed25519)
            return 0
            ;;
    esac
    return 1
}

is_protected_manifest_path() {
    local rel="$1"
    path_has_component "$rel" ".git" && return 0
    path_has_component "$rel" ".beads" && return 0
    is_credential_path "$rel" && return 0
    return 1
}

validate_manifest_path() {
    local rel="$1"
    [[ -n "$rel" ]] || return 1
    [[ "$rel" != /* ]] || return 1
    [[ "$rel" != "." ]] || return 1
    path_has_parent_ref "$rel" && return 1
    return 0
}

validate_source_tree() {
    local scaffold_dir="$1" manifest="$2"
    [[ -d "$scaffold_dir" ]] || error_exit "missing scaffold directory: $scaffold_dir"
    [[ -f "$manifest" ]] || error_exit "missing scaffold manifest: $manifest"

    local line_no=0 kind rel action description normalized src
    while IFS=$'\t' read -r kind rel action description || [[ -n "${kind:-}" ]]; do
        line_no=$((line_no + 1))
        [[ -z "${kind:-}" || "${kind:0:1}" == "#" ]] && continue
        normalized="$(normalize_rel_path "$rel")"

        validate_manifest_path "$normalized" \
            || error_exit "invalid manifest path at line $line_no: $rel"
        is_protected_manifest_path "$normalized" \
            && error_exit "manifest line $line_no targets protected path: $rel"

        src="$scaffold_dir/$normalized"
        case "$kind:$action" in
            file:copy)
                [[ -f "$src" ]] || error_exit "manifest line $line_no missing source file: $rel"
                ;;
            dir:ensure_dir|transient_dir:ensure_ignored)
                [[ -d "$src" ]] || error_exit "manifest line $line_no missing source directory: $rel"
                ;;
            *)
                error_exit "invalid manifest kind/action at line $line_no: $kind $action"
                ;;
        esac
    done < "$manifest"
}

add_created() {
    CREATED_LINES+=("  $1 | action=$2 | reason=$3")
}

add_skipped() {
    SKIPPED_LINES+=("  $1 | action=$2 | reason=$3")
}

add_conflict() {
    CONFLICT_LINES+=("  path: $1"$'\n'"    planned_action: $2"$'\n'"    reason: $3"$'\n'"    suggested_resolution: $4")
}

add_apply() {
    APPLY_KINDS+=("$1")
    APPLY_PATHS+=("$2")
    APPLY_ACTIONS+=("$3")
}

file_matches_managed_content() {
    local rel="$1" src="$2" dest="$3"
    local src_text dest_text beads_gitignore_block
    MANAGED_MATCH_REASON="already matches scaffold"

    if cmp -s -- "$src" "$dest"; then
        return 0
    fi

    if [[ "$rel" == ".gitignore" ]]; then
        src_text="$(<"$src")"
        dest_text="$(<"$dest")"
        beads_gitignore_block=$'\n\n# Beads / Dolt files (added by bd init)\n.dolt/\n*.db\n.beads-credential-key'
        if [[ "$dest_text" == "$src_text$beads_gitignore_block" ]]; then
            MANAGED_MATCH_REASON="already matches scaffold plus Beads ignore rules"
            return 0
        fi
    fi

    return 1
}

print_lines_or_none() {
    local -n lines_ref="$1"
    if ((${#lines_ref[@]} == 0)); then
        printf '  none\n'
        return 0
    fi

    local line
    for line in "${lines_ref[@]}"; do
        printf '%s\n' "$line"
    done
}

print_plan_report() {
    local heading="$1" source_dir="$2" target_abs="$3" prefix="$4" force="$5" bd_required="$6"

    cat <<EOF
$heading
source_dir: $source_dir
target: $target_abs
prefix: $prefix
force: $force
bd_required: $bd_required

created paths:
EOF
    print_lines_or_none CREATED_LINES

    printf '\nskipped paths:\n'
    print_lines_or_none SKIPPED_LINES

    printf '\nconflicts:\n'
    print_lines_or_none CONFLICT_LINES
}

print_install_summary() {
    local mode="$1" target_abs="$2"
    local write_note

    case "$mode" in
        dry-run)
            write_note="dry-run only; no target files were written"
            ;;
        blocked)
            write_note="install blocked; no scaffold files were written"
            ;;
        *)
            write_note="install completed"
            ;;
    esac

    cat <<EOF

installer summary:
  result: $write_note
  target instructions: $target_abs/AGENTS.md
  opt-in config guide: $target_abs/docs/opt-in-configs.md
  Beads status: $BEADS_STATUS
  next workflow skills: session-start, brainstormer, grill-with-docs, product-architect, project-planner, plan-to-beads-unified, tdd, minion, session-wrapup
EOF
}

parent_chain_conflicts() {
    local target_abs="$1" rel="$2"
    local parent_rel parent_abs
    parent_rel="$(dirname -- "$rel")"
    [[ "$parent_rel" == "." ]] && return 1

    local current="" part
    IFS='/' read -r -a parts <<<"$parent_rel"
    for part in "${parts[@]}"; do
        [[ -z "$part" ]] && continue
        if [[ -z "$current" ]]; then
            current="$part"
        else
            current="$current/$part"
        fi
        parent_abs="$target_abs/$current"
        if [[ -L "$parent_abs" ]]; then
            add_conflict "$current" "prepare_parent" "parent path is a symlink" "replace the symlink with a real directory before retrying"
            return 0
        fi
        if [[ -e "$parent_abs" && ! -d "$parent_abs" ]]; then
            add_conflict "$current" "prepare_parent" "parent path exists but is not a directory" "move or rename this path before retrying"
            return 0
        fi
    done
    return 1
}

plan_file() {
    local scaffold_dir="$1" target_abs="$2" rel="$3" force="$4"
    local src="$scaffold_dir/$rel" dest="$target_abs/$rel"

    if parent_chain_conflicts "$target_abs" "$rel"; then
        return 0
    fi

    if [[ -L "$dest" ]]; then
        add_conflict "$rel" "copy" "target path is a symlink" "replace the symlink manually; --force will not write through symlinks"
        return 0
    fi

    if [[ -e "$dest" ]]; then
        if [[ ! -f "$dest" ]]; then
            add_conflict "$rel" "copy" "target path exists but is not a regular file" "move or remove this path manually before retrying"
            return 0
        fi
        if file_matches_managed_content "$rel" "$src" "$dest"; then
            add_skipped "$rel" "copy" "$MANAGED_MATCH_REASON"
            return 0
        fi
        if ((force)); then
            add_created "$rel" "overwrite" "managed scaffold file differs and --force was supplied"
            add_apply "file" "$rel" "copy"
            return 0
        fi

        add_conflict "$rel" "copy" "managed scaffold file already exists with different content" "review the file, move it aside, or rerun with --force to overwrite this managed file"
        return 0
    fi

    add_created "$rel" "copy" "managed scaffold file is absent"
    add_apply "file" "$rel" "copy"
}

plan_dir() {
    local target_abs="$1" rel="$2" action="$3"
    local dest="$target_abs/$rel"

    if parent_chain_conflicts "$target_abs" "$rel"; then
        return 0
    fi

    if [[ -L "$dest" ]]; then
        add_conflict "$rel" "$action" "target path is a symlink" "replace the symlink manually; --force will not write through symlinks"
        return 0
    fi

    if [[ -d "$dest" ]]; then
        add_skipped "$rel/" "$action" "directory already exists"
        return 0
    fi

    if [[ -e "$dest" ]]; then
        add_conflict "$rel/" "$action" "target path exists but is not a directory" "move or remove this path manually before retrying"
        return 0
    fi

    add_created "$rel/" "$action" "managed scaffold directory is absent"
    add_apply "dir" "$rel" "$action"
}

validate_existing_beads() {
    local target_abs="$1"
    if bd -C "$target_abs" ping --quiet >/dev/null 2>&1; then
        return 0
    fi
    return 1
}

plan_beads() {
    local target_abs="$1" prefix="$2" dry_run="$3"
    local beads_path="$target_abs/.beads"

    if [[ -L "$beads_path" ]]; then
        BEADS_STATUS="blocked: existing .beads path is a symlink"
        add_conflict ".beads/" "validate_beads" "existing .beads path is a symlink" "replace it with a valid Beads database directory or choose a different target"
        return 0
    fi

    if [[ -d "$beads_path" ]]; then
        if ((dry_run)); then
            BEADS_STATUS="existing .beads/ will be validated during real install"
            add_skipped ".beads/" "validate_beads" "existing Beads database will be validated during real install"
            return 0
        fi
        if validate_existing_beads "$target_abs"; then
            BEADS_STATUS="existing .beads/ validated with bd"
            add_skipped ".beads/" "validate_beads" "existing Beads database is valid"
            return 0
        fi
        BEADS_STATUS="blocked: bd could not validate existing .beads/"
        add_conflict ".beads/" "validate_beads" "bd could not validate the existing Beads database" "repair the database with bd doctor or move it aside manually before retrying"
        return 0
    fi

    if [[ -e "$beads_path" ]]; then
        BEADS_STATUS="blocked: .beads path exists but is not a directory"
        add_conflict ".beads/" "bd_init" "path exists but is not a directory" "move or remove this path manually before retrying"
        return 0
    fi

    BEADS_STATUS="will initialize .beads/ with prefix $prefix during real install"
    add_created ".beads/" "bd_init" "Beads database is absent and will be initialized with prefix $prefix"
}

plan_install() {
    local scaffold_dir="$1" manifest="$2" target_abs="$3" prefix="$4" dry_run="$5" force="$6"
    local line_no=0 kind rel action description normalized

    while IFS=$'\t' read -r kind rel action description || [[ -n "${kind:-}" ]]; do
        line_no=$((line_no + 1))
        [[ -z "${kind:-}" || "${kind:0:1}" == "#" ]] && continue
        normalized="$(normalize_rel_path "$rel")"

        case "$kind:$action" in
            file:copy)
                plan_file "$scaffold_dir" "$target_abs" "$normalized" "$force"
                ;;
            dir:ensure_dir|transient_dir:ensure_ignored)
                plan_dir "$target_abs" "$normalized" "$action"
                ;;
            *)
                error_exit "invalid manifest line $line_no after validation"
                ;;
        esac
    done < "$manifest"

    plan_beads "$target_abs" "$prefix" "$dry_run"
}

apply_install() {
    local scaffold_dir="$1" target_abs="$2" prefix="$3"
    local i kind rel action src dest parent

    mkdir -p -- "$target_abs"

    for i in "${!APPLY_PATHS[@]}"; do
        kind="${APPLY_KINDS[$i]}"
        rel="${APPLY_PATHS[$i]}"
        action="${APPLY_ACTIONS[$i]}"
        dest="$target_abs/$rel"

        case "$kind:$action" in
            file:copy)
                src="$scaffold_dir/$rel"
                parent="$(dirname -- "$dest")"
                mkdir -p -- "$parent"
                cp -f -- "$src" "$dest"
                ;;
            dir:ensure_dir|dir:ensure_ignored)
                mkdir -p -- "$dest"
                ;;
            *)
                error_exit "internal error: unknown apply operation $kind:$action"
                ;;
        esac
    done

    if [[ ! -d "$target_abs/.beads" ]]; then
        (cd -- "$target_abs" && bd init --non-interactive --skip-agents --skip-hooks --prefix "$prefix")
        BEADS_STATUS="initialized .beads/ with prefix $prefix"
    fi
}

ensure_not_self_install() {
    local source_dir="$1" target_abs="$2"
    if [[ "$target_abs" == "$source_dir" ]]; then
        error_exit "refusing to install the scaffold into itself: $target_abs"
    fi
}

main() {
    local source_dir target="" target_abs prefix="" dry_run=0 force=0 mode="auto" resolved_mode
    local scaffold_dir manifest
    source_dir="$(script_dir)"
    scaffold_dir="$source_dir/assets/scaffold"
    manifest="$scaffold_dir/manifest.txt"

    parse_args target prefix dry_run force mode "$@"
    resolve_mode "$mode" "$target" "$prefix" resolved_mode

    if [[ "$resolved_mode" == "interactive" ]]; then
        if ! has_tty_context || is_ci_context; then
            die "--interactive requires a TTY and cannot run in CI or non-TTY mode"
        fi
        run_interactive_mode "$target" "$prefix"
        return $?
    fi

    validate_non_interactive_inputs "$target" "$prefix"
    target_abs="$(realpath -m -- "$target")"

    ensure_not_self_install "$source_dir" "$target_abs"
    validate_source_tree "$scaffold_dir" "$manifest"

    if ((!dry_run)) && ! command -v bd >/dev/null 2>&1; then
        cat >&2 <<EOF
bootstrap: bd is required for real installs and was not found on PATH.
No target files were written.

Install or expose bd, then retry:
  bd --help
  ./bootstrap --prefix $prefix $target_abs
EOF
        exit 1
    fi

    declare -g -a CREATED_LINES=()
    declare -g -a SKIPPED_LINES=()
    declare -g -a CONFLICT_LINES=()
    declare -g -a APPLY_KINDS=()
    declare -g -a APPLY_PATHS=()
    declare -g -a APPLY_ACTIONS=()
    declare -g BEADS_STATUS="not planned"

    plan_install "$scaffold_dir" "$manifest" "$target_abs" "$prefix" "$dry_run" "$force"

    if ((dry_run)); then
        print_plan_report "bootstrap dry-run" "$source_dir" "$target_abs" "$prefix" "$force" "no"
        print_install_summary "dry-run" "$target_abs"
        return 0
    fi

    if ((${#CONFLICT_LINES[@]})); then
        print_plan_report "bootstrap install blocked" "$source_dir" "$target_abs" "$prefix" "$force" "yes"
        print_install_summary "blocked" "$target_abs"
        return 1
    fi

    apply_install "$scaffold_dir" "$target_abs" "$prefix"
    print_plan_report "bootstrap install complete" "$source_dir" "$target_abs" "$prefix" "$force" "yes"
    print_install_summary "install" "$target_abs"
}

main "$@"
